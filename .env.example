# Fichier d'exemple des variables d'environnement
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins

# ==============================================
# CONFIGURATION DE BASE DE DONNÉES
# ==============================================

# PostgreSQL
POSTGRES_DB=gestion_commerciale
POSTGRES_USER=gestion_user
POSTGRES_PASSWORD=gestion_password_secure_2024

# URLs de connexion Prisma
DATABASE_URL="postgresql://gestion_user:gestion_password_secure_2024@localhost:6432/gestion_commerciale"
DIRECT_DATABASE_URL="postgresql://gestion_user:gestion_password_secure_2024@localhost:5432/gestion_commerciale"

# ==============================================
# CONFIGURATION REDIS
# ==============================================

REDIS_PASSWORD=redis_password_secure_2024
REDIS_URL="redis://:redis_password_secure_2024@localhost:6379"

# ==============================================
# CONFIGURATION BACKEND
# ==============================================

# JWT Secrets (CHANGEZ CES VALEURS EN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Serveur
NODE_ENV="development"
PORT=3001
HOST="0.0.0.0"

# CORS - Port standardisé pour le frontend
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW="1 minute"

# Logs
LOG_LEVEL="info"
LOG_PRETTY=true

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./uploads"

# ==============================================
# CONFIGURATION FRONTEND - STANDARDIZED ON PORT 3000
# ==============================================

# API Backend
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Frontend URL - Standardized on port 3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Développement
NEXT_PUBLIC_DEV_MODE=true

# ==============================================
# CONFIGURATION OPTIONNELLE
# ==============================================

# Email (pour les notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
