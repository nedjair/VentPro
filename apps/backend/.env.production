# Configuration de production
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Frontend URL pour CORS
FRONTEND_URL=http://localhost:3000

# JWT Secret (à changer en production)
JWT_SECRET=your-super-secret-jwt-key-for-production-change-this-in-real-production

# Limites
MAX_FILE_SIZE=10485760

# Logs
LOG_LEVEL=info
