{
  "name": "@gestion/backend",
  "version": "1.0.0",
  "description": "API Backend Fastify pour l'application de gestion commerciale",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "prisma:generate": "prisma generate --schema=../../packages/database/schema.prisma",
    "dev": "npm run prisma:generate && tsx watch src/index.ts",
    "dev:skip-generate": "tsx watch src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "seed:stocks": "tsx scripts/seed-stocks.ts",
    "test:stock-module": "tsx scripts/test-stock-module.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@gestion/database": "file:../../packages/database",
    "@gestion/shared": "file:../../packages/shared",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "node-cron": "^4.1.1",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.1",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "redis": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ]
  }
}
