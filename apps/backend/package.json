{
  "name": "@gestion/backend",
  "version": "1.0.0",
  "description": "API Backend Fastify pour l'application de gestion commerciale",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run prisma:generate:safe && tsx watch src/index.ts",
    "dev:skip-generate": "tsx watch src/index.ts",
    "dev:force": "npm run dev:skip-generate",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "clean": "rm -rf dist && rm -rf node_modules/.cache",
    "prisma:generate": "prisma generate --schema=../../packages/database/schema.prisma",
    "prisma:generate:safe": "node scripts/safe-prisma-generate.js",
    "prisma:migrate": "prisma migrate dev --schema=../../packages/database/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=../../packages/database/schema.prisma",
    "prisma:studio": "prisma studio --schema=../../packages/database/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=../../packages/database/schema.prisma --force",
    "db:seed": "tsx scripts/seed-database.ts --dry-run",
    "db:seed:dev": "tsx scripts/seed-database.ts --confirm-reset",
    "db:seed:stocks": "tsx scripts/seed-stocks.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vitest": "vitest",
    "test:vitest:watch": "vitest --watch",
    "test:vitest:coverage": "vitest --coverage",
    "test:stock-module": "tsx scripts/test-stock-module.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t ventespro-backend .",
    "docker:run": "docker run -p 3001:3001 ventespro-backend"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@gestion/database": "file:../../packages/database",
    "@gestion/shared": "file:../../packages/shared",
    "@prisma/client": "6.19.2",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.10.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.1.1",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.1",
    "pino": "^9.2.0",
    "pino-pretty": "^13.0.0",
    "prisma": "6.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@vitest/ui": "^3.2.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ]
  }
}
