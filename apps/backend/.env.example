# Base de données
# En local, la stack Docker VentesPro expose PostgreSQL sur localhost:5434.
# Garder DATABASE_URL et DIRECT_DATABASE_URL alignées évite les ambiguïtés
# entre Prisma, les scripts Node.js et les tests manuels.
DATABASE_URL="postgresql://tpe_user:tpe_password_2024@localhost:5434/gestion_commerciale_tpe"
DIRECT_DATABASE_URL="postgresql://tpe_user:tpe_password_2024@localhost:5434/gestion_commerciale_tpe"

# JWT Secrets
# - minimum recommandé : 32 caractères
# - la valeur ci-dessous est réservée au développement/local
# - en production, remplacez-la impérativement par une vraie valeur aléatoire
JWT_SECRET="change-this-development-jwt-secret-min-32-chars"
# Conservé pour compatibilité documentaire, même si le backend actuel signe encore
# access token + refresh token avec le secret JWT principal.
JWT_REFRESH_SECRET="change-this-development-refresh-secret-min-32ch"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Application
NODE_ENV="development"
PORT=3001
HOST="0.0.0.0"

# CORS
# Liste explicite des origines frontend autorisées.
# Plusieurs valeurs possibles, séparées par des virgules.
# Exemple Docker/local : http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
# Alias simple si vous préférez documenter une seule origine principale.
FRONTEND_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW="1 minute"

# Logs
LOG_LEVEL="info"
LOG_PRETTY=true

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./uploads"

# Email (optionnel pour les notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Monitoring (optionnel)
SENTRY_DSN=""
