# URL publique optionnelle de l'API côté navigateur.
# Laisser vide est le comportement recommandé : le frontend utilise alors
# des appels relatifs `/api/v1/*` et laisse Next.js proxyfier via le rewrite.
NEXT_PUBLIC_API_BASE_URL=

# URL interne utilisée uniquement par le serveur Next.js pour les rewrites.
# - Local hors Docker : http://localhost:3001
# - Docker Compose :   http://backend:3001
# Cette variable n'est pas préfixée par NEXT_PUBLIC_ car elle ne doit pas être
# exposée au navigateur.
INTERNAL_API_BASE_URL=http://localhost:3001