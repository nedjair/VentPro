{
  "name": "@gestion/frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start -p 3000",
    "start:prod": "NODE_ENV=production next start -p 3000",
    "clean": "rm -rf .next && rm -rf out && rm -rf node_modules/.cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "export": "next export",
    "docker:build": "docker build -t ventespro-frontend .",
    "docker:run": "docker run -p 3006:3006 ventespro-frontend"
  },
  "dependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.515.0",
    "next": "^14.2.30",
    "node-cron": "^4.1.1",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.0.2",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/file-saver": "^2.0.7",
    "@types/jspdf": "^1.3.3",
    "@types/node": "20.19.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "jsdom": "^23.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "5.8.3",
    "vitest": "^1.0.4"
  }
}
