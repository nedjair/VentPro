# Windows: privilégie un node_modules plat pour limiter les problèmes de symlinks.
node-linker=hoisted

# Évite qu'un `pnpm install` lancé dans un sous-projet installe tout le workspace.
recursive-install=false

# Réduit les symlinks dans le virtual store pour limiter les erreurs EPERM.
symlink=false

# Préfère la copie depuis le store pour éviter les comportements fragiles de liens.
package-import-method=copy

# Réduit la longueur des chemins dans le virtual store sous Windows.
virtual-store-dir-max-length=40